<?xml version="1.0"?>
<!DOCTYPE suppressions PUBLIC
    "-//Checkstyle//DTD SuppressionFilter Configuration 1.2//EN"
    "https://checkstyle.org/dtds/suppressions_1_2.dtd">

<suppressions>
    <!-- EC P-256 domain parameters and other dense byte arrays in PaymentApplication -->
    <suppress files="PaymentApplication\.java" checks="WhitespaceAfter" lines="42-110"/>

    <!-- GenerateAcCdaTest uses star imports and non-standard import order (pre-existing) -->
    <suppress files="GenerateAcCdaTest\.java" checks="AvoidStarImport|CustomImportOrder"/>
</suppressions>
